#include<stdio.h>
#include<locale.h>
#include<string.h>
#include <stdlib.h>

struct menu_livro {
	char nome_livros[50];
	int num_livro[50];
	char nome_autor[50];
	char nome_autor2[50];
	int num_paginas[50];
};

int main() {
	setlocale(LC_ALL, "Portuguese");

	struct menu_livro livro[50];

	int i = 0;
	int escolha, registro, opcao = 0;
	int total = 0;

	printf("\t\tMENU\t\n");

	do {
		
			printf("-----------------------------------\n");
			printf("PRESSIONA 1. PARA ADICIONAR OS DETALHES DO LIVRO\n");
			printf("PRESSIONA 2. PARA MOSTRAR OS DETALHES DO LIVRO.\n");
			printf("PRESSIONA 3. PARA MOSTRAR O LIVRO DO AUTOR DADO\n");
			printf("PRESSIONA 4. PARA CONTAR O NÚMERO DE LIVROS.\n");
			printf("PRESSIONA 5. PARA SAIR DO PROGRAMA.\n");

		printf("\n-----------------------------------\n");

		printf("\nInsere a tua escolha: \n");
		scanf_s("%d", &escolha);

		switch (escolha) {

			//primeira opção do menu
		case 1:
			printf("\nQuantos registos pretendes inserir? \n");
			scanf_s("%d", &registro);

			getchar(); // limpar o /n

			for (i = 0; i < registro; i++) {
				printf("-----------------------------------\n");

				printf("\nInsere o número do livro: \n");
				scanf_s("%d", &livro[i].num_livro);
				getchar(); // limpar o /n

				printf("\nInsere o nome do livro: \n");
				scanf_s("%s", &livro[i].nome_livros);


				printf("\nInsere o nome do autor: \n");
				scanf_s("%s", &livro[i].nome_autor);
			

				printf("\ninsere o número de páginas: \n");
				scanf_s("%d", &livro[i].num_paginas);

				getchar(); // limpar o /n

				total ++;
				break;

			} 
			// segunda opção do menu

		case 2:
			printf("\t\t detalhes dos livros \t");
			printf("\n--------------------------------------------------------------------------------\n");
			printf("%-15s %-20s %-20s %-10s\n",
				"número do livro", "nome do livro", "nome do autor", "número de páginas");
			printf("\n--------------------------------------------------------------------------------\n");

			for (i = 0; i < total; i++) {
				printf("%-15d %-20s %-20s %-10d\n",
					livro[i].num_livro,
					livro[i].nome_livros,
					livro[i].nome_autor,
					livro[i].num_paginas);

				continue;
			}

			// terceira opção
		case 3:
			 
			printf("Insere o nome do autor: \n");
			scanf_s("%s", &livro[i].nome_autor2);

			printf("\n------------------------------------------\n");
			printf("Insere a tua escolha: ");
			scanf_s("%d", &escolha);

			printf("Insere o nome do livro: \n");
			scanf_s("%s", &livro[i].nome_livros);

			continue;

			//quarta opção
		case 4:
			printf("\nNúmero total de livros na biblioteca: %d", total);
			continue;

			//quinta e ultima opção
		case 5:
			printf("\nA sair do programa\n");
			system("pause");
			break;
		}
	}
	while (opcao >= 5);
	return 0;
}
